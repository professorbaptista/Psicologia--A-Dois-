<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Agendamento</title>
     <link rel="icon" type="image/x-png" sizes="16x16" href="/images/favicon.ico">
</head>
<body>
    <%- include('partials/header', { title: 'Agendamento'})  %>
        <main class="main-container">
            <div class="container">
                <h2><%= titulo %></h2>
                <% if(success_msg) { %>
                    <div class="msg">
                        <p class="success"><%= success_msg %></p>
                    </div>
                <% } else if(error_msg){ %>
                    <div class="msg">
                        <p class="error"><%= error_msg %></p>
                    </div>
                <% } %>
                <!-- Filtro de agendamentos -->
               <div class="filter">
                <form action="/agendamento" method="GET" class="form-contro">
                    <label>Filtrar</label>
                  <input type="text" name="name" placeholder="filtrar por nome...">
                  <input type="text" name="tipo_servicos" placeholder="Filtrar por serviço...">
                  <button type="submit" class="form-control-bt">Filtrar</button>
                </form>
              </div>
                <div class="voltar">
                    <a href="/agendar" class="form-control-btn">Voltar</a>
                </div> 
            
                <!-- <% if(message) { %>
                    <div class="message">
                        <p><%= message %></p>
                    </div>
               <% } else { %>
                <div class="error">
                    <p><%= error %></p>
                </div>
               <% } %>  -->

                <% if(agendamentos.length > 0){ %>

                    <% agendamentos.forEach(ag => { %>
                    <div class="agendamento">

              <ul class="ul">
                        <li class="name">Nome: <strong><%= ag.name %></strong> </li>
                        <li>Data: <%= ag.data %> às <%= ag.hora %> </li>
                        <li>Serviços: <%= ag.tipo_servicos %> </li>
                        <li style="text-align: center; font-size: 1.2rem; color: beige; border-top: 2px solid lightblue;">Mensagem</li> 
                        <li><%= ag.message %></li>
                    
                          <!-- Botoes editar e deletar -->
                        <span class="span">
                        <li>
                        <a href="/editar/<%= ag.id %>" class="editar">Editar</a>
                        </li>
                        <li>
                        <form action="/deletarAgendamento/<%= ag.id %>" method="get">
                            <button class="deletar" type="submit">Deletar</button>
                        </form>
                    </li>
                    </span>
                    </ul>

                    <!-- Comentarios -->
                          <% comments.forEach(co => { %>
                        <ul>
                            <li><%= co.name %></li>
                            <li><%= co.comment %></li>
                       
                        </ul>

                       <% }) %>

                       <!-- Contactos dos clientes -->
                        <% contactos.forEach(c => { %>
                            <ul>
                                <li><%= contato %></li>
                                <li><%= c.name %></li>
                                <li><%= c.email %></li>
                                <li><%= c.message %></li>
                            </ul>      
                        <% }) %>

                    </div>
                <% }) %>

                <% } else { %>
                    <p style="text-align: center; font-size: 1.4rem; margin-top: 20px;">Nenhum agendamento encontrado. </p>
               <% } %>
               
                
